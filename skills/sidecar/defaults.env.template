# Sidecar vendor → model alias map. Seeded into the state dir as defaults.env
# on setup; per-user, lives next to .env.local. `ask.sh --model <vendor>`
# resolves vendor words through the SIDECAR_MODEL_<VENDOR> lines below.
#
# OpenRouter's catalog turns over — when a slug starts 404ing, refresh it:
#   bash <SKILL_DIR>/scripts/refresh-defaults.sh                    # see candidates
#   bash <SKILL_DIR>/scripts/refresh-defaults.sh gemini <new-slug>  # remap
#
# Anthropic/Claude is deliberately not seeded: Sidecar exists for second
# opinions from models OTHER than the parent Claude. Explicit Claude asks
# still work with a full slug (e.g. --model anthropic/claude-sonnet-4.6).
SIDECAR_MODEL_GEMINI="google/gemini-3.1-pro-preview"
SIDECAR_MODEL_GPT="openai/gpt-5.5"
SIDECAR_MODEL_DEEPSEEK="deepseek/deepseek-v4-flash"
SIDECAR_MODEL_GROK="x-ai/grok-4.3"
SIDECAR_MODEL_LLAMA="meta-llama/llama-4-maverick"
