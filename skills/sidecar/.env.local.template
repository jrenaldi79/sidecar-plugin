# Sidecar local config — copied to .env.local on install.
# Do not commit. .env.local is per-user.

# =========================================================================
# Proxy upstream config — consumed when starting anthropic-proxy
# =========================================================================
# Get/rotate at https://openrouter.ai/keys
OPENROUTER_API_KEY="REPLACE_WITH_YOUR_OPENROUTER_KEY"

# OpenRouter model the proxy forwards to. Run scripts/list-models.sh to browse.
# Sidecar is for adversarial second opinions from a DIFFERENT model than the
# parent Claude, so the defaults below are deliberately non-Anthropic.
# Recommendation snapshot (Apr 2026 — verify with list-models.sh before relying):
#   google/gemini-3.1-pro-preview
#   openai/gpt-5.5
#   deepseek/deepseek-v4-flash
#   x-ai/grok-4.3
COMPLETION_MODEL="google/gemini-3.1-pro-preview"
REASONING_MODEL="google/gemini-3.1-pro-preview"

# Local port for the proxy.
PORT=3000

# Stream upstream responses through the proxy. Default behavior (this var
# unset OR "true"): honor the client's payload.stream value, which means
# streaming is on for `claude -p`. Set to "false" only if a specific
# upstream's SSE format breaks the stream parser. THINKING MODELS (Gemini
# 3.x Pro, GPT-5.5 reasoning, etc.) require streaming-on to surface their
# `reasoning` field — the non-streaming path drops it.
SIDECAR_STREAMING="true"

# =========================================================================
# Claude CLI config — consumed when running claude -p through the proxy
# =========================================================================
# Routes the CLI to the local proxy instead of OpenRouter directly.
ANTHROPIC_BASE_URL="http://127.0.0.1:3000"

# CLI requires a non-empty key or it refuses to start. Proxy ignores the value.
ANTHROPIC_API_KEY="proxy-ignores-this"
